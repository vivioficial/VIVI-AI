# Vivi AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ──────────────────────────────────────────────────────────────
# Firebase Configuration (required for auth and data storage)
# Get these values from your Firebase project settings:
# https://console.firebase.google.com/
# ──────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ──────────────────────────────────────────────────────────────
# AI / LLM Configuration (at least one is recommended)
# ──────────────────────────────────────────────────────────────

# OpenAI — enables GPT-4 chat, DALL-E images, TTS voice, and vision
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# Google Gemini — alternative LLM backend
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────────────────────
# Application Settings (optional)
# ──────────────────────────────────────────────────────────────
VITE_APP_NAME=Vivi AI
VITE_APP_VERSION=1.0.0

# ──────────────────────────────────────────────────────────────
# Base44 (optional — only needed when running inside Base44 builder)
# ──────────────────────────────────────────────────────────────
# VITE_ENABLE_BASE44_PLUGIN=true
